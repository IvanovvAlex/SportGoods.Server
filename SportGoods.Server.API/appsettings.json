{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=sportgoodsdb;Username=postgres;Password=postgres;"
  },
  "Jwt": {
    "Issuer": "SportGoods.Server.API",
    "Audience": "SportGoods.Server.API.Client",
    "Secret": "ReplaceThisDevelopmentJwtSecretWithARealProductionSecret1234567890",
    "AccessTokenExpiryMinutes": 120,
    "RefreshTokenExpiryDays": 30
  },
  "ClientApp": {
    "BaseUrl": "http://localhost:5173"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "https://sportgoods-client.onrender.com"
    ]
  },
  "Email": {
    "DeliveryMode": "Console",
    "SenderEmail": "noreply@sportgoods.local",
    "SenderName": "SportGoods",
    "PasswordResetTokenExpiryMinutes": 30
  },
  "Payments": {
    "OnlineProviderName": "DemoSportPay",
    "OnlinePaymentLabel": "Online card payment",
    "SupportedMethods": ["online-card", "bank-transfer"],
    "BankTransfer": {
      "Beneficiary": "SportGoods Ltd.",
      "Iban": "BG00DEMO12345678901234",
      "Bic": "DEMOBGSF",
      "BankName": "Demo Bank",
      "ReferencePrefix": "SPORT"
    }
  },
  "Inventory": {
    "LowStockThreshold": 10
  },
  "DevelopmentSettings": {
    "ResetDatabaseOnStart": false,
    "ExposeEmailPreviewLinks": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
